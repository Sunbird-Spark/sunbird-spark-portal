{
  "name": "sunbirded-portal",
  "version": "1.0.0",
  "description": "sunbird backend",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:full": "npm run build && npm run copy:frontend",
    "copy:frontend": "mkdir -p dist/public && [ -d ../frontend/dist ] && cp -r ../frontend/dist/* dist/public/ || echo 'Frontend dist not found, skipping copy'",
    "start": "[ \"$NODE_ENV\" = \"production\" ] && npm run build:full && node dist/server.js || npm run build && node dist/server.js",
    "test": "env-cmd -f .envExample vitest",
    "test:ui": "env-cmd -f .envExample vitest --ui",
    "test:run": "env-cmd -f .envExample vitest run",
    "test:coverage": "env-cmd -f .envExample vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@yugabytedb/pg": "^8.7.3-yb-10",
    "ajv": "^8.17.1",
    "axios": "^1.13.2",
    "cassandra-driver": "^4.8.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "keycloak-connect": "^26.1.1",
    "lodash": "^4.17.21",
    "pg": "^8.16.3",
    "snyk": "^1.1301.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cassandra-driver": "^4.1.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/keycloak-connect": "^4.5.4",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "env-cmd": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "prettier": "^3.7.4",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
