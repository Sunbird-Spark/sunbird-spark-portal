    "axios": "^1.13.2",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "lodash": "^4.17.21",
    "pg": "^8.16.3",
    "snyk": "^1.1301.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "yb-ycql-driver": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cassandra-driver": "^4.1.1",
