## Playwright UI automation inputs
## Copy to `.env` and adjust as needed.

# Where the learner starts
START_URL="https://sandbox.sunbirded.org/resources?board=CBSE&medium=English&gradeLevel=Class%201&subject=English&id=NCF&selectedTab=home"

# Optional: only required if the app shows a login form during the flow
USER_EMAIL="user2@yopmail.com"
USER_PASSWORD="User2@123"

# Course selection (choose one)
# 1) Exact-ish title (converted to a case-insensitive regex internally)
COURSE_TITLE=""

# 2) Raw regex pattern. You can use either:
#    - plain string: ^\s*assessment\s+course\s*$
#    - /.../flags style: /^\s*assessment\s+course\s*$/i
COURSE_TITLE_PATTERN=""

